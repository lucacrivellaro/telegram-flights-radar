# --- Telegram (obbligatori) -------------------------------------------------
# Token del bot: crealo con @BotFather su Telegram
TELEGRAM_BOT_TOKEN=
# ID della chat che riceve le offerte: scrivi al bot e leggi l'ID con
# https://api.telegram.org/bot<TOKEN>/getUpdates (campo message.chat.id)
TELEGRAM_CHAT_ID=

# --- Travelpayouts (consigliato: abilita scali e altre compagnie) -----------
# Token API: registrati gratis su travelpayouts.com → Profilo → API token
TRAVELPAYOUTS_TOKEN=
# Marker affiliato (opzionale, per i deep-link Aviasales)
TRAVELPAYOUTS_MARKER=

# --- Ricerca -----------------------------------------------------------------
ORIGIN_AIRPORTS=VRN,BGY
# Finestra di ricerca: da domani a N giorni avanti
SEARCH_DAYS_AHEAD=45
# Whitelist destinazioni (codici IATA, vuota = tutte) es: LIS,BCN,OPO
DESTINATIONS_WHITELIST=
# Blacklist destinazioni es: TIA,CRL
DESTINATIONS_BLACKLIST=

# --- Cosa conta come "offerta" ------------------------------------------------
PRICE_THRESHOLD_EUROPE=40
PRICE_THRESHOLD_EXTRA=300
# Sconto % minimo rispetto alla media storica della rotta
DISCOUNT_THRESHOLD_PCT=30
# Rilevazioni minime prima di fidarsi della media storica
MIN_HISTORY_SAMPLES=5
# Quante offerte al massimo nel messaggio giornaliero
TOP_N=8
# Non re-inviare la stessa offerta per N giorni (salvo cali di prezzo >10%)
RESEND_COOLDOWN_DAYS=3

# --- Scheduler -----------------------------------------------------------------
DAILY_TIME=08:00
TIMEZONE=Europe/Rome

# --- Persistenza -----------------------------------------------------------------
DB_PATH=data/flights.db
